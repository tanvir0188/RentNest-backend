model User {
  id             String          @id @default(uuid())
  name           String
  email          String          @unique
  password       String
  activeStatus   ActiveStatus    @default(ACTIVE)
  role           Role            @default(TENANT)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  profile        Profile?
  payments       Payment[]
  properties     Property[]
  reviews        Review[]
  rentalRequests RentalRequest[]

  @@map("users")
}
